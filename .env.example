# Copy to .env and fill in your values.
# On Azure, set these as App Settings instead.

# Path to the folder containing game data (sub-folders named by game ID)
DATA_ROOT_DIR=/path/to/your/game/data

# Output directory for generated files
OUTPUT_DIR=./output

# SportLogIQ API (optional, only needed for data ingestion)
# SPORTLOGIQ_USERNAME=
# SPORTLOGIQ_PWD=
# SPORTLOGIQ_API_URL=https://api.sportlogiq.com

# Database (optional, only needed for DB ingestion scripts)
# DATABASE_HOST=mysql-flex-public.mysql.database.azure.com
# DATABASE_USERNAME=
# DATABASE_PWD=
# DATABASE_NAME=sportlogiq
# DATABASE_SSL_CA=~/DigiCertGlobalRootCA.crt.pem
